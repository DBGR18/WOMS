APP_ENV=local
HTTP_ADDR=:8080
JWT_SECRET=change-me-in-production
AUTH_MODE=local
AUTH_SESSION_STORE=
CORS_ALLOWED_ORIGIN=*
API_STORE=postgres
DEMO_SEED_DATA=true
DATABASE_URL=postgres://woms:woms@postgres:5432/woms?sslmode=disable
REDIS_ADDR=redis:6379
KAFKA_BROKERS=kafka:9092
KAFKA_SCHEDULE_TOPIC=woms.schedule.jobs
KAFKA_CONSUMER_GROUP=woms-scheduler-workers
KAFKA_PUBLISH_ENABLED=true
WORKER_MIN_JOB_DURATION_MS=500
WORKER_MAX_RETRIES=3
WORKER_LOCK_TTL_MS=15000
WORKER_LOCK_RENEW_INTERVAL_MS=5000
WORKER_LOCK_TIMEOUT_MS=10000
WORKER_START_OFFSET=latest
DOCKERHUB_NAMESPACE=your-dockerhub-namespace
WOMS_IMAGE_TAG=latest
API_UPSTREAM=api:8080
