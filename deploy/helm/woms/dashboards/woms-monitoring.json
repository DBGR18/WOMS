      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum by (method, path, status) (rate(woms_http_requests_total[5m]))",
          "legendFormat": "{{method}} {{path}} · {{status}}",
          "refId": "A"
